{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.{css,js,png,jpg,jpeg,webp,svg,ico,avif}"]
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  },
  "mimeTypes": {
    ".json": "application/json",
    ".html": "text/html"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
